{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Shoal API",
  "theme": "mint",
  "logo": {
    "dark": "/images/logo-white.svg",
    "light": "/images/logo-black.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#FF6B35",
    "light": "#FF8C5A",
    "dark": "#E85A2A"
  },
  "navbar": {
    "links": [
      {
        "label": "Get API Key",
        "href": "https://app.shoal.xyz"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/shoalresearch",
      "github": "https://github.com/shoalresearch"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Using the API",
            "pages": [
              "guides/pagination",
              "guides/errors",
              "guides/rate-limits",
              "guides/versioning",
              "guides/best-practices",
              "guides/examples"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Overview",
            "pages": ["integrations/overview"]
          },
          {
            "group": "SDK & Tools",
            "pages": ["integrations/cli"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Organizations",
            "pages": [
              "api-reference/organizations/get-all",
              "api-reference/organizations/by-organization-id",
              "api-reference/organizations/by-organization-name",
              "api-reference/organizations/signal-history"
            ]
          },
          {
            "group": "Radar",
            "pages": [
              "api-reference/radar/get-all",
              "api-reference/radar/by-organization-id",
              "api-reference/radar/by-category"
            ]
          },
          {
            "group": "Signal",
            "pages": [
              "api-reference/signal/top",
              "api-reference/signal/get-all",
              "api-reference/signal/by-organization-id",
              "api-reference/signal/by-category"
            ]
          },
          {
            "group": "Brief",
            "pages": [
              "api-reference/brief/get",
              "api-reference/brief/batch"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/overview",
              "api-reference/webhooks/create",
              "api-reference/webhooks/list",
              "api-reference/webhooks/delete"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api-reference/categories",
              "api-reference/usage"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "mdx": {
      "server": "https://api.shoal.xyz",
      "auth": {
        "method": "bearer"
      }
    }
  }
}
