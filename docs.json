{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Shoal API",
  "theme": "mint",
  "logo": {
    "dark": "/images/logo-white.svg",
    "light": "/images/logo-black.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#FF6B35",
    "light": "#FF8C5A",
    "dark": "#E85A2A"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "api-reference/authentication",
              "guides/pagination",
              "guides/errors",
              "guides/rate-limits",
              "guides/versioning",
              "guides/best-practices",
              "guides/examples"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Overview",
            "pages": ["integrations/overview"]
          },
          {
            "group": "SDK & Tools",
            "pages": ["integrations/cli"]
          },
          {
            "group": "Payments",
            "pages": ["integrations/mpp"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Organizations",
            "pages": [
              "api-reference/organizations/get-all",
              "api-reference/organizations/by-organization-id",
              "api-reference/organizations/by-organization-name"
            ]
          },
          {
            "group": "Radar",
            "pages": [
              "api-reference/radar/get-all",
              "api-reference/radar/by-organization-id",
              "api-reference/radar/by-category"
            ]
          },
          {
            "group": "Signal",
            "pages": [
              "api-reference/signal/get-all",
              "api-reference/signal/by-organization-id",
              "api-reference/signal/by-category"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "mdx": {
      "server": "https://api.shoal.xyz",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "colors": {
    "primary": "#FF6B35",
    "light": "#FF8C5A",
    "dark": "#E85A2A"
  }
}
